name: Sync Daily

on:
  schedule:
    - cron: '0 4 * * *' # Ogni giorno alle 04:00
  workflow_dispatch: # Ti permette di cliccare "Run workflow" a mano per testare

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout target repo
        uses: actions/checkout@v3
        with:
          fetch-depth: 0

      - name: Sync from Upstream
        run: |
          # Configura l'utente
          git config --global user.name "GitHub Action"
          git config --global user.email "action@github.com"
          
          # Aggiungi il repo originale come sorgente (upstream)
          git remote add upstream https://github.com/Realbestia1/Easyproxy.git
          
          # Scarica le novità
          git fetch upstream
          
          # Forza l'aggiornamento del tuo main con quello originale
          git checkout main
          git reset --hard upstream/main
          
          # Spingi le modifiche nel TUO repository
          git push origin main --force
